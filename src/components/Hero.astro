---
interface Props {
  titulo: string;
  bajada: string;
  ctaTexto?: string;
  ctaHref?: string;
}

const {
  titulo,
  bajada,
  ctaTexto = "Ver servicios",
  ctaHref = "#servicios",
} = Astro.props;
---

<section class="hero section">
  <div class="container hero__inner">
    <div class="hero__content reveal">
      <span class="hero__tag">Diseño · Desarrollo · Estrategia</span>
      <h1 class="hero__titulo">{titulo}</h1>
      <p class="hero__bajada">{bajada}</p>
      <div class="hero__actions">
        <a href={ctaHref} class="btn btn--primary btn--lg">{ctaTexto}</a>
        <a href="#nosotros" class="btn btn--ghost btn--lg">Conocenos</a>
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__shape"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg-soft);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
    min-height: 80vh;
  }
  .hero__tag {
    display: inline-block;
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }
  .hero__titulo {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }
  .hero__bajada {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 480px;
    margin-bottom: var(--space-lg);
  }
  .hero__actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .btn--lg {
    padding: 0.75rem 2rem;
    font-size: var(--font-size-base);
  }
  .btn--ghost {
    background: transparent;
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
  }
  .btn--ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .hero__visual {
    display: flex;
    justify-content: center;
  }
  .hero__shape {
    width: 400px;
    height: 400px;
    border-radius: 40% 60% 60% 40% / 40% 40% 60% 60%;
    background: linear-gradient(
      135deg,
      var(--color-accent) 0%,
      var(--color-secondary) 100%
    );
    opacity: 0.15;
  }
  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero__visual {
      display: none;
    }
    .hero__titulo {
      font-size: var(--font-size-3xl);
    }
  }
</style>
